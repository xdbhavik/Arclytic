# Google Gemini settings
LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"

# Fast model for rapid generation
LLM_MODEL="gemini-3.1-flash-lite-preview" 

# For higher quality (but slower/more expensive) results, uncomment the line below:
# LLM_MODEL="gemini-1.5-pro"

LLM_API_KEY="your_api_key_here"

# --- Optional NLP Settings ---
# Set to 'true' to use real huggingface models for text feature embeddings and sentiment analysis.
# USE_REAL_NLP=true
